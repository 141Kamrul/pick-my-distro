// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hash this in production!
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FilterAttribute {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // 'select' | 'multi-select' | 'range' | 'boolean' | 'text'
  options     String[] // JSON array stored as text
  minValue    Int?
  maxValue    Int?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  distros DistroAttribute[]
}

model Distro {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  image       String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  attributes DistroAttribute[]
}

model DistroAttribute {
  id          String   @id @default(cuid())
  distroId    String
  attributeId String
  value       String   // Store as JSON string for flexibility
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  distro    Distro           @relation(fields: [distroId], references: [id], onDelete: Cascade)
  attribute FilterAttribute  @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  
  @@unique([distroId, attributeId])
}
